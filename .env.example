# ============================================
# CRIT Server 환경 변수 설정 파일
# ============================================
# 이 파일을 .env로 복사하고 실제 값으로 채워주세요
# .env 파일은 .gitignore에 포함되어 있습니다

# ============================================
# Google APIs
# ============================================
# Google Gemini API 키
GEMINI_API_KEY=your_gemini_api_key_here

# YouTube Data API v3 키
YOUTUBE_API_KEY=your_youtube_api_key_here

# GCP 서비스 계정 키 파일 경로
# 주의: gcp-key.json 파일은 git에 포함되지 않습니다
# clone/pull 후 gcp-key.json을 crit-server/gcp-key/ 디렉토리에 직접 배치하세요
GCP_KEY_PATH=./gcp-key/gcp-key.json

# ============================================
# AWS Configuration
# ============================================
# AWS 리전
AWS_REGION=us-east-1

# AWS Bedrock 모델 ID
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# AWS S3 버킷명
AWS_S3_BUCKET=your-s3-bucket-name

# ============================================
# Database Configuration
# ============================================
# MySQL 데이터베이스 URL
SPRING_DATASOURCE_URL=jdbc:mysql://your-db-host:3306/crit?useSSL=false&serverTimezone=Asia/Seoul&allowPublicKeyRetrieval=true

# 데이터베이스 사용자명
SPRING_DATASOURCE_USERNAME=your_db_username

# 데이터베이스 비밀번호
SPRING_DATASOURCE_PASSWORD=your_db_password

# ============================================
# Application Configuration
# ============================================
# Spring 프로필 (dev, prod 등)
SPRING_PROFILES_ACTIVE=dev

# 서버 포트
SERVER_PORT=8080

# JPA DDL 자동 생성 (create, update, validate, none)
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# SQL 로깅 활성화
SPRING_JPA_SHOW_SQL=true
